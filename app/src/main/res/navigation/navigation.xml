<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navigation"
    app:startDestination="@id/simulacaoFragment">

    <fragment
        android:id="@+id/simulacaoFragment"
        android:name="com.example.myapplication.ui.fragments.SimulacaoFragment"
        android:label="SimulacaoFragment">
        <action
            android:id="@+id/action_simulacaoFragment_to_negociacaoFragment"
            app:destination="@id/negociacaoFragment" />
    </fragment>

    <fragment
        android:id="@+id/negociacaoFragment"
        android:name="com.example.myapplication.ui.fragments.NegociacaoFragment"
        android:label="NegociacaoFragment">
        <action
            android:id="@+id/action_negociacaoFragment_to_simulacaoFreteeFragment"
            app:destination="@id/simulacaoFreteeFragment" />
        <argument android:name="cargaTotal" app:argType="integer" android:defaultValue="0" />
        <argument android:name="pesoMedio" app:argType="float" android:defaultValue="0.0" />
    </fragment>

    <fragment
        android:id="@+id/simulacaoFreteeFragment"
        android:name="com.example.myapplication.ui.fragments.SimulacaoFreteFragment"
        android:label="SimulacaoFreteeFragment">
        <argument android:name="cargaTotal" app:argType="integer" android:defaultValue="0" />
        <argument android:name="pesoMedio" app:argType="float" android:defaultValue="0.0" />
    </fragment>

</navigation>